rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    // === Users ===
    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
      allow read, write: if isAdmin();

      match /activity/{activityId} {
        allow read, write: if isSignedIn() && request.auth.uid == userId;
        allow read, write: if isAdmin();
      }

      // Reef game state — owner can read; writes only via Cloud Functions
      // (admin SDK bypasses rules) so points/energy can't be forged client-side.
      match /game/{doc} {
        allow read: if isSignedIn() && request.auth.uid == userId;
        allow read, write: if isAdmin();
      }
    }

    // === Reef: fish catalog (admin-managed, readable by all signed-in) ===
    match /fish/{fishId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    // === Reef: reward catalog ===
    match /rewards/{rewardId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    // === Reef: redemption requests (created via Cloud Functions) ===
    match /redemptions/{rId} {
      allow read: if isSignedIn()
        && (resource.data.userId == request.auth.uid || isAdmin());
      allow update, delete: if isAdmin();
    }

    // === Reef: leaderboard (written by Cloud Functions) ===
    match /leaderboard/{uid} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // === Reef: global game docs e.g. fish of the hour (written by functions) ===
    match /games/{doc} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // === Plans (admin-managed templates, readable by all signed-in users) ===
    match /plans/{planId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    // === Withdrawal requests ===
    match /withdrawals/{wId} {
      allow read: if isSignedIn()
        && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.status == 'pending';
      allow update, delete: if isAdmin();
    }

    // === Top-up requests ===
    match /topups/{tId} {
      allow read: if isSignedIn()
        && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.status == 'pending';
      allow update, delete: if isAdmin();
    }

    // === Platform settings (readable by all signed-in, writable by admin) ===
    match /settings/{doc} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // === collectionGroup('activity') reads — admins only across all users ===
    match /{path=**}/activity/{activityId} {
      allow read: if isAdmin();
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
