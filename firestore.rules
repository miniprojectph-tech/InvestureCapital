rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    // === Users ===
    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
      allow read, write: if isAdmin();

      match /activity/{activityId} {
        allow read, write: if isSignedIn() && request.auth.uid == userId;
        allow read, write: if isAdmin();
      }

      // Reef game state — owner can read; writes only via Cloud Functions
      // (admin SDK bypasses rules) so points/energy can't be forged client-side.
      match /game/{doc} {
        allow read: if isSignedIn() && request.auth.uid == userId;
        allow read, write: if isAdmin();
      }
    }

    // === Reef: fish catalog (admin-managed, readable by all signed-in) ===
    match /fish/{fishId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    // === Reef: reward catalog ===
    match /rewards/{rewardId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    // === Reef: redemption requests (created via Cloud Functions) ===
    match /redemptions/{rId} {
      allow read: if isSignedIn()
        && (resource.data.userId == request.auth.uid || isAdmin());
      allow update, delete: if isAdmin();
    }

    // === Reef: leaderboard (written by Cloud Functions) ===
    match /leaderboard/{uid} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // === Reef: global game docs e.g. fish of the hour (written by functions) ===
    match /games/{doc} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // === Plans (admin-managed templates, readable by all signed-in users) ===
    match /plans/{planId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    // === Withdrawal requests ===
    match /withdrawals/{wId} {
      allow read: if isSignedIn()
        && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.status == 'pending';
      allow update, delete: if isAdmin();
    }

    // === Top-up requests ===
    match /topups/{tId} {
      allow read: if isSignedIn()
        && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.status == 'pending';
      allow update, delete: if isAdmin();
    }

    // === Plan activation requests ===
    match /plan_requests/{rId} {
      allow read: if isSignedIn()
        && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.status == 'pending';
      allow update, delete: if isAdmin();
    }

    // === Platform settings (readable by all signed-in, writable by admin) ===
    match /settings/{doc} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // === Referral code index (code -> uid) ===
    // Publicly readable by signed-in users so a new signup can resolve ?ref=CODE
    // to the referrer's uid (they can't query the users collection). A user may
    // only claim a code that points at their own uid, and never overwrite one.
    match /referralCodes/{code} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.uid == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // === Referral transactions (the affiliate ledger) ===
    // The referred user files a 'queued' claim for their own activation; a Cloud
    // Function (admin SDK, bypasses rules) validates it and credits the referrer.
    // Both parties can read their own rows; only admins/functions mutate.
    match /referral_transactions/{txnId} {
      allow read: if isSignedIn()
        && (resource.data.referrerUserId == request.auth.uid
            || resource.data.referredUserId == request.auth.uid
            || isAdmin());
      allow create: if isSignedIn()
        && request.resource.data.referredUserId == request.auth.uid
        && request.resource.data.status == 'queued';
      allow update, delete: if isAdmin();
    }

    // === Community Tongits: rooms (Phase 1) ===
    // Public lobby → any signed-in user can read. All mutations go through Cloud
    // Functions (admin SDK bypasses rules); direct client writes are denied.
    match /game_rooms/{code} {
      allow read: if isSignedIn();
      allow write: if isAdmin();

      // Public game state — room members read; Functions write.
      match /game/{doc} {
        allow read: if isSignedIn()
          && (isAdmin()
              || get(/databases/$(database)/documents/game_rooms/$(code)).data.players[request.auth.uid] != null);
        allow write: if isAdmin();
      }

      // Private hands — only the owning player can read their own cards.
      match /hands/{playerId} {
        allow read: if isSignedIn() && (request.auth.uid == playerId || isAdmin());
        allow write: if isAdmin();
      }

      // Hidden deck/stock — never client-readable (Functions/admin only).
      match /secret/{doc} {
        allow read, write: if isAdmin();
      }

      // Chat: only players listed in the room may post/read; messages are
      // author-stamped and length-limited. Reads limited to room members.
      match /chat/{msgId} {
        allow read: if isSignedIn()
          && (isAdmin()
              || get(/databases/$(database)/documents/game_rooms/$(code)).data.players[request.auth.uid] != null);
        allow create: if isSignedIn()
          && request.resource.data.uid == request.auth.uid
          && request.resource.data.message is string
          && request.resource.data.message.size() > 0
          && request.resource.data.message.size() <= 300
          && get(/databases/$(database)/documents/game_rooms/$(code)).data.players[request.auth.uid] != null
          && get(/databases/$(database)/documents/game_rooms/$(code)).data.chatEnabled == true;
        allow update: if false;
        allow delete: if isAdmin();
      }
    }

    // === Community Tongits: chat reports (players file, admins moderate) ===
    match /game_chat_reports/{reportId} {
      allow read: if isAdmin();
      allow create: if isSignedIn() && request.resource.data.reporterUserId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // === Community Tongits: player reports (players file, admins moderate) ===
    match /game_player_reports/{reportId} {
      allow read: if isAdmin();
      allow create: if isSignedIn() && request.resource.data.reporterUid == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // === Community Tongits: point transaction ledger (Functions write) ===
    match /game_point_transactions/{txnId} {
      allow read: if isSignedIn()
        && (resource.data.userId == request.auth.uid || isAdmin());
      allow write: if isAdmin();
    }

    // === Community Tongits: leaderboard (Functions write, public read) ===
    match /tongits_leaderboard/{uid} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // === Community Tongits: match records (Functions write) ===
    match /game_matches/{matchId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    match /game_match_results/{resultId} {
      allow read: if isSignedIn()
        && (resource.data.userId == request.auth.uid || isAdmin());
      allow write: if isAdmin();
    }

    // === collectionGroup('activity') reads — admins only across all users ===
    match /{path=**}/activity/{activityId} {
      allow read: if isAdmin();
    }

    // === collectionGroup('game') reads — admins only (per-investor game admin) ===
    match /{path=**}/game/{gameDoc} {
      allow read: if isAdmin();
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
